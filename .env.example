NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=3001
WEB_ORIGIN=http://127.0.0.1:5173

# Leave empty to use the embedded local PostgreSQL-compatible database.
# Production example: postgres://user:password@host:5432/el_triunfo
DATABASE_URL=
PGLITE_DATA_DIR=.data/postgres

# Use at least 32 random characters in production.
JWT_SECRET=replace-with-a-long-random-production-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=7

VITE_API_URL=/api
VITE_BACKEND_MODE=api
VITE_BASE_PATH=/
