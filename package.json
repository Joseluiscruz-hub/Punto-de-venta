{
  "name": "punto-de-venta-el-triunfo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c blue,green \"npm:dev:api\" \"npm:dev:web:wait\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:web:wait": "wait-on http-get://127.0.0.1:3001/api/health && npm run dev:web",
    "dev:api": "tsx watch server/src/index.ts",
    "api": "tsx server/src/index.ts",
    "build": "npm run build:web && npm run build:api",
    "build:web": "tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "build:api": "tsc -p tsconfig.server.json",
    "test": "tsx --test src/**/*.test.ts server/src/**/*.test.ts",
    "lint": "eslint .",
    "db:migrate": "tsx server/src/migrate.ts",
    "db:seed": "tsx server/src/seed-cli.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "lucide-react": "^0.546.0",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "read-excel-file": "^9.2.0",
    "recharts": "^2.15.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10"
  }
}
